{
  "name": "bitplus-signal",
  "version": "0.1.0",
  "description": "Public-intent signal finder for BTC++ and technical conference communities.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "bitplus-signal": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node dist/cli.js build --events data/events/btcplusplus-2026.json --signals data/reviewed/toronto-real-signals.json --out public/data --event-id btcpp-toronto-2026 --trust-graph data/trust/toronto-trust-seeds.json data/reviewed/toronto-real-trust-slice.json --source-log data/sources/real-data-run-log.json",
    "build:sample": "tsc && node dist/cli.js build --events data/events/btcplusplus-2026.json --signals data/samples/toronto-signals.json --out public/data --event-id btcpp-toronto-2026 --trust-graph data/trust/toronto-trust-seeds.json",
    "build:all": "tsc && node dist/cli.js build --events data/events/btcplusplus-2026.json --signals data/samples/signals.json --out public/data",
    "dev": "npm run build && npx serve public",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "models:check": "tsx src/cli.ts model-check",
    "scan:toronto:nostr": "tsx src/cli.ts scan-nostr --query \"BTC++ Toronto\" --out data/real/nostr-toronto.json --timeout-ms 15000",
    "review:nostr-graph": "tsx src/cli.ts review-nostr-graph --graph data/real/nostr-trust-graph.json --out data/reviewed/toronto-real-signals.json --trust-slice-out data/reviewed/toronto-real-trust-slice.json --limit 12 --source-lane nostr_graph --posted-at 2026-06-17",
    "scan:toronto:apify": "tsx src/cli.ts apify-import --actor xquik/x-tweet-scraper --input data/sources/apify-xquik-btcplusplus-input.example.json --out data/real/apify-xquik-btcplusplus.json --timeout 180",
    "scan:toronto:apify:reddit": "tsx src/cli.ts apify-import --actor automation-lab/reddit-scraper --input data/sources/apify-reddit-toronto-search-input.example.json --out data/real/apify-reddit-toronto.json --timeout 180",
    "scan:toronto:apify:x-expanded": "tsx src/cli.ts apify-import --actor xquik/x-tweet-scraper --input data/sources/apify-xquik-expanded-social-input.example.json --out data/real/apify-xquik-expanded-social.json --raw-out data/real/apify-xquik-expanded-social.raw.json --timeout 240 --max-charged-items 80",
    "scan:toronto:apify:reddit-expanded": "tsx src/cli.ts apify-import --actor automation-lab/reddit-scraper --input data/sources/apify-reddit-expanded-social-input.example.json --out data/real/apify-reddit-expanded-social.json --raw-out data/real/apify-reddit-expanded-social.raw.json --timeout 240 --max-charged-items 80",
    "scan:toronto:apify:linkedin": "tsx src/cli.ts apify-import --actor khadinakbar/linkedin-posts-scraper --input data/sources/apify-linkedin-expanded-social-input.example.json --out data/real/apify-linkedin-expanded-social.json --raw-out data/real/apify-linkedin-expanded-social.raw.json --timeout 240 --max-charged-items 80",
    "scan:toronto:apify:tiktok": "tsx src/cli.ts apify-import --actor clockworks/tiktok-scraper --input data/sources/apify-tiktok-expanded-social-input.example.json --out data/real/apify-tiktok-expanded-social.json --raw-out data/real/apify-tiktok-expanded-social.raw.json --timeout 240 --max-charged-items 60",
    "scan:toronto:apify:instagram": "tsx src/cli.ts apify-import --actor apify/instagram-scraper --input data/sources/apify-instagram-expanded-social-input.example.json --out data/real/apify-instagram-expanded-social.json --raw-out data/real/apify-instagram-expanded-social.raw.json --timeout 240 --max-charged-items 60",
    "scan:toronto:apify:facebook": "tsx src/cli.ts apify-import --actor apify/facebook-posts-scraper --input data/sources/apify-facebook-expanded-social-input.example.json --out data/real/apify-facebook-expanded-social.json --raw-out data/real/apify-facebook-expanded-social.raw.json --timeout 240 --max-charged-items 60",
    "review:social-expanded": "tsx src/cli.ts review-social --base data/reviewed/toronto-real-signals.json --input data/reviewed/toronto-adjacent-event-signals.json data/real/apify-xquik-expanded-social.json data/real/apify-reddit-expanded-social.json data/real/apify-linkedin-expanded-social.json data/real/apify-tiktok-expanded-social.json data/real/apify-instagram-expanded-social.json data/real/apify-facebook-expanded-social.json --out data/reviewed/toronto-real-signals.json --blocked-out data/real/review-social-expanded-blocked.json --fallback-threshold 10",
    "scan:toronto:apify:x-subscribed": "tsx src/cli.ts apify-import --actor xquik/x-tweet-scraper --input data/sources/apify-xquik-subscribed-sweep-input.example.json --out data/real/apify-xquik-subscribed-sweep.json --raw-out data/real/apify-xquik-subscribed-sweep.raw.json --timeout 360 --max-charged-items 300",
    "scan:toronto:apify:reddit-subscribed": "tsx src/cli.ts apify-import --actor automation-lab/reddit-scraper --input data/sources/apify-reddit-subscribed-sweep-input.example.json --out data/real/apify-reddit-subscribed-sweep.json --raw-out data/real/apify-reddit-subscribed-sweep.raw.json --timeout 360 --max-charged-items 300",
    "scan:toronto:apify:linkedin-subscribed": "tsx src/cli.ts apify-import --actor khadinakbar/linkedin-posts-scraper --input data/sources/apify-linkedin-subscribed-sweep-input.example.json --out data/real/apify-linkedin-subscribed-sweep.json --raw-out data/real/apify-linkedin-subscribed-sweep.raw.json --timeout 360 --max-charged-items 300",
    "scan:toronto:apify:instagram-subscribed": "tsx src/cli.ts apify-import --actor apify/instagram-scraper --input data/sources/apify-instagram-subscribed-sweep-input.example.json --out data/real/apify-instagram-subscribed-sweep.json --raw-out data/real/apify-instagram-subscribed-sweep.raw.json --timeout 360 --max-charged-items 150",
    "scan:toronto:apify:tiktok-subscribed": "tsx src/cli.ts apify-import --actor clockworks/tiktok-scraper --input data/sources/apify-tiktok-subscribed-sweep-input.example.json --out data/real/apify-tiktok-subscribed-sweep.json --raw-out data/real/apify-tiktok-subscribed-sweep.raw.json --timeout 360 --max-charged-items 150",
    "scan:toronto:apify:facebook-subscribed": "tsx src/cli.ts apify-import --actor apify/facebook-posts-scraper --input data/sources/apify-facebook-subscribed-sweep-input.example.json --out data/real/apify-facebook-subscribed-sweep.json --raw-out data/real/apify-facebook-subscribed-sweep.raw.json --timeout 360 --max-charged-items 150",
    "scan:toronto:apify:subscribed": "npm run scan:toronto:apify:x-subscribed && npm run scan:toronto:apify:reddit-subscribed && npm run scan:toronto:apify:linkedin-subscribed && npm run scan:toronto:apify:instagram-subscribed && npm run scan:toronto:apify:tiktok-subscribed && npm run scan:toronto:apify:facebook-subscribed",
    "review:social-subscribed": "tsx src/cli.ts review-social --base data/reviewed/toronto-real-signals.json --input data/reviewed/toronto-adjacent-event-signals.json data/real/apify-xquik-subscribed-sweep.json data/real/apify-reddit-subscribed-sweep.json data/real/apify-linkedin-subscribed-sweep.json data/real/apify-instagram-subscribed-sweep.json data/real/apify-tiktok-subscribed-sweep.json data/real/apify-facebook-subscribed-sweep.json --out data/reviewed/toronto-real-signals.json --blocked-out data/real/review-social-subscribed-blocked.json --fallback-threshold 10",
    "refresh:subscribed": "npm run scan:toronto:apify:subscribed && npm run review:social-subscribed && npm run build",
    "review:historical-public": "tsx src/cli.ts review-social --base data/reviewed/toronto-real-signals.json --input data/reviewed/toronto-historical-public-signals.json --out data/reviewed/toronto-real-signals.json --blocked-out data/real/review-historical-public-blocked.json --reference-date 2026-06-17 --primary-window-days 520 --fallback-window-days 520 --fallback-threshold 1 --exclude-start-date 2026-04-18 --exclude-end-date 2026-06-17",
    "review:community-public": "tsx src/cli.ts review-social --base data/reviewed/toronto-real-signals.json --input data/reviewed/toronto-community-public-signals.json --out data/reviewed/toronto-real-signals.json --blocked-out data/real/review-community-public-blocked.json --reference-date 2026-06-17 --primary-window-days 520 --fallback-window-days 520 --fallback-threshold 1 --exclude-start-date 2026-04-18 --exclude-end-date 2026-06-17",
    "scan:toronto:apify:x-historical": "tsx src/cli.ts apify-import --actor xquik/x-tweet-scraper --input data/sources/apify-xquik-historical-backfill-input.example.json --out data/real/apify-xquik-historical-backfill.json --raw-out data/real/apify-xquik-historical-backfill.raw.json --timeout 360 --max-charged-items 300",
    "scan:toronto:apify:reddit-historical": "tsx src/cli.ts apify-import --actor automation-lab/reddit-scraper --input data/sources/apify-reddit-historical-backfill-input.example.json --out data/real/apify-reddit-historical-backfill.json --raw-out data/real/apify-reddit-historical-backfill.raw.json --timeout 360 --max-charged-items 300",
    "scan:toronto:apify:linkedin-historical": "tsx src/cli.ts apify-import --actor khadinakbar/linkedin-posts-scraper --input data/sources/apify-linkedin-historical-backfill-input.example.json --out data/real/apify-linkedin-historical-backfill.json --raw-out data/real/apify-linkedin-historical-backfill.raw.json --timeout 360 --max-charged-items 300",
    "scan:toronto:apify:instagram-historical": "tsx src/cli.ts apify-import --actor apify/instagram-scraper --input data/sources/apify-instagram-historical-backfill-input.example.json --out data/real/apify-instagram-historical-backfill.json --raw-out data/real/apify-instagram-historical-backfill.raw.json --timeout 360 --max-charged-items 150",
    "scan:toronto:apify:tiktok-historical": "tsx src/cli.ts apify-import --actor clockworks/tiktok-scraper --input data/sources/apify-tiktok-historical-backfill-input.example.json --out data/real/apify-tiktok-historical-backfill.json --raw-out data/real/apify-tiktok-historical-backfill.raw.json --timeout 360 --max-charged-items 150",
    "scan:toronto:apify:facebook-historical": "tsx src/cli.ts apify-import --actor apify/facebook-posts-scraper --input data/sources/apify-facebook-historical-backfill-input.example.json --out data/real/apify-facebook-historical-backfill.json --raw-out data/real/apify-facebook-historical-backfill.raw.json --timeout 360 --max-charged-items 150",
    "scan:toronto:apify:historical": "npm run scan:toronto:apify:x-historical && npm run scan:toronto:apify:reddit-historical && npm run scan:toronto:apify:linkedin-historical && npm run scan:toronto:apify:instagram-historical && npm run scan:toronto:apify:tiktok-historical && npm run scan:toronto:apify:facebook-historical",
    "review:social-historical": "tsx src/cli.ts review-social --base data/reviewed/toronto-real-signals.json --input data/reviewed/toronto-historical-public-signals.json data/real/apify-xquik-historical-backfill.json data/real/apify-reddit-historical-backfill.json data/real/apify-linkedin-historical-backfill.json data/real/apify-instagram-historical-backfill.json data/real/apify-tiktok-historical-backfill.json data/real/apify-facebook-historical-backfill.json --out data/reviewed/toronto-real-signals.json --blocked-out data/real/review-social-historical-blocked.json --reference-date 2026-06-17 --primary-window-days 180 --fallback-window-days 520 --fallback-threshold 10 --exclude-start-date 2026-04-18 --exclude-end-date 2026-06-17",
    "refresh:historical": "npm run scan:toronto:apify:historical && npm run review:social-historical && npm run build",
    "scan:private": "node scripts/private-scan.mjs",
    "deck:build": "node scripts/build-pitch-deck.mjs",
    "verify": "npm run lint && npm test && npm run build && npm run scan:private"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "csv-parse": "^6.1.0",
    "nostr-tools": "^2.17.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@types/node": "^24.10.1",
    "serve": "^14.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
